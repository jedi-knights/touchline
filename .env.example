# Copy to `.env` and edit. `.env` is gitignored.

# ---- Postgres (used by compose to provision the postgres service) ----
POSTGRES_USER=touchline
POSTGRES_PASSWORD=touchline
POSTGRES_DB=touchline
POSTGRES_PORT=5432

# ---- App ----
APP_PORT=3000

# Drizzle / app DB connection. For local non-Docker dev, point at localhost.
DATABASE_URL=postgres://touchline:touchline@localhost:5432/touchline

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ---- identity-service (vendored from identity-platform-go) ----
# The Next.js app calls this for credential validation; Auth.js still
# issues the session cookie. For local non-Docker dev, point at localhost.
IDENTITY_SERVICE_URL=http://localhost:8081
IDENTITY_LOG_LEVEL=info
IDENTITY_LOG_ENVIRONMENT=development

# ---- match-engine (Go service authored in services/match-engine) ----
# Touchline's Server Actions delegate match-event recording and substitutions
# to this service. State machine + DB writes live in Go; tenant scoping
# (assertOwnsMatch) stays in Next.js. For local non-Docker dev, point at
# localhost.
MATCH_ENGINE_URL=http://localhost:8082
MATCH_ENGINE_LOG_LEVEL=info

# ---- api-gateway (vendored from identity-platform-go) ----
# Front-door reverse proxy. In compose it owns the host port mapping
# (APP_PORT above) and reverse-proxies to the internal app:3000.
# Rate limiting and compression are enabled by default; auth + CORS
# are off (Auth.js cookies handle sessions; same-origin).
GATEWAY_LOG_LEVEL=info
GATEWAY_LOG_ENVIRONMENT=development

# Adminer (optional, opt-in via the `tools` compose profile)
ADMINER_PORT=8080
